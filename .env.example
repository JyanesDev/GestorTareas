# Copia este archivo como .env y rellena los valores:
#   cp .env.example .env

# PostgreSQL
POSTGRES_DB=gestor_tareas
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=